# Gwen AI - Environment Configuration

# OpenRouter API Key (Required for AI responses)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter Model (Optional - Default: deepseek)
# Options: deepseek, qwen, mistral, llama, gemini
OPENROUTER_MODEL=deepseek

# Firebase Configuration (Optional - for cloud sync)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY="your_private_key"
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_CLIENT_ID=your_client_id
FIREBASE_CLIENT_CERT_URL=your_client_cert_url

# Voice Settings
VOICE_ENABLED=true
VOICE_SPEED=180
VOICE_VOLUME=0.9

# Wake Word
WAKE_WORD_ENABLED=true

# Notification Settings
NOTIFICATIONS_ENABLED=true
MOTIVATION_INTERVAL=120
HYDRATION_INTERVAL=60
